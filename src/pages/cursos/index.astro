---
import Page from '../../layouts/Page.astro';

const categories = ['Todos', 'Frontend', 'Backend', 'Data Science', 'Diseno', 'DevOps'];

const courses = [
  {
    title: 'JavaScript Moderno desde Cero',
    tag: 'Frontend', tagClass: 'tag-blue',
    instructor: 'Carlos Mendoza', duration: '40 horas', level: 'Principiante',
