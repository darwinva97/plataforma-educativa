---
const instructors = [
  {
    name: 'Carlos Mendoza',
    specialty: 'JavaScript & Frontend',
    courses: 12,
    students: 4500,
    bio: 'Senior Frontend Engineer con 10 anos de experiencia. Ex-Globant, apasionado por ensenar desarrollo web moderno.',
    image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=300&h=300&fit=crop&crop=face',
  },
  {
    name: 'Maria Gutierrez',
    specialty: 'React & TypeScript',
    courses: 8,
    students: 3200,
    bio: 'Full Stack Developer y Tech Lead. Especialista en React y arquitectura frontend escalable.',
    image: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=300&h=300&fit=crop&crop=face',
  },
  {
    name: 'Diego Ramirez',
    specialty: 'Python & Data Science',
    courses: 10,
    students: 2800,
    bio: 'Data Scientist con experiencia en machine learning. PhD en Ciencias de la Computacion.',
    image: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=300&h=300&fit=crop&crop=face',
  },
  {
    name: 'Valentina Rojas',
    specialty: 'UX/UI Design',
    courses: 6,
    students: 3800,
    bio: 'Disenadora UX/UI con enfoque en productos digitales. Ex-diseadora en Rappi y Platzi.',
    image: 'https://images.unsplash.com/photo-1580489944761-15a19d654956?w=300&h=300&fit=crop&crop=face',
  },
];
---
<section class="section section-alt">
  <div class="container">
    <div class="section-header">
      <h2>Nuestros <span class="text-gradient">Instructores</span></h2>
      <p>Aprende de profesionales con experiencia real en la industria tecnologica.</p>
    </div>
    <div class="instructors-grid">
      {instructors.map(inst => (
        <div class="instructor-card">
          <div class="instructor-img">
            <img src={inst.image} alt={inst.name} loading="lazy" />
          </div>
          <div class="instructor-info">
            <h3>{inst.name}</h3>
            <span class="instructor-spec">{inst.specialty}</span>
            <p class="instructor-bio">{inst.bio}</p>
            <div class="instructor-stats">
              <span>{inst.courses} cursos</span>
              <span>{inst.students.toLocaleString()} estudiantes</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .instructors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .instructor-card {
    background: var(--bg);
    border-radius: var(--radius);
    padding: 2rem 1.5rem;
    text-align: center;
    border: 1px solid var(--border);
    transition: var(--transition);
  }
  .instructor-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .instructor-img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto 1.25rem;
    border: 3px solid var(--border);
  }
  .instructor-img img { width: 100%; height: 100%; object-fit: cover; }
  .instructor-info h3 { font-size: 1.1rem; margin-bottom: 0.25rem; }
  .instructor-spec {
    display: inline-block;
    color: var(--primary-light);
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .instructor-bio {
    color: var(--text-light);
    font-size: 0.85rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  .instructor-stats {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-light);
  }
</style>
